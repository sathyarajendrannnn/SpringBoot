#### 📄 Student.java (Model)
```java
package com.example.model;

import lombok.Data;
import lombok.AllArgsConstructor;
import lombok.NoArgsConstructor;

@Data
@AllArgsConstructor
@NoArgsConstructor
public class Student {
    private int id;
    private String name;
    private int age;
}
```

---

#### 📄 StudentRepository.java — `@Repository`
```java
package com.example.repository;

import com.example.model.Student;
import org.springframework.stereotype.Repository;
import java.util.*;

@Repository   // Data Access Layer — talks to DB
public class StudentRepository {

    // Simulating a database with a Map
    private Map<Integer, Student> db = new HashMap<>();

    public void save(Student s) {
        db.put(s.getId(), s);
        System.out.println("Saved to DB: " + s.getName());
    }

    public Student findById(int id) {
        return db.get(id);
    }

    public List<Student> findAll() {
        return new ArrayList<>(db.values());
    }
}
```

---

#### 📄 StudentService.java — `@Service`
```java
package com.example.service;

import com.example.model.Student;
import com.example.repository.StudentRepository;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;
import java.util.List;

@Service   // Business Logic Layer
public class StudentService {

    @Autowired
    private StudentRepository studentRepository;  // injected automatically

    public void addStudent(Student s) {
        // business logic can go here (validation, etc.)
        System.out.println("Service: adding student...");
        studentRepository.save(s);
    }

    public Student getStudent(int id) {
        return studentRepository.findById(id);
    }

    public List<Student> getAllStudents() {
        return studentRepository.findAll();
    }
}
```

---

#### 📄 StudentController.java — `@Controller`
```java
package com.example.controller;

import com.example.model.Student;
import com.example.service.StudentService;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Controller;
import java.util.List;

@Controller   // Presentation Layer
public class StudentController {

    @Autowired
    private StudentService studentService;  // injected automatically

    public void addStudent(Student s) {
        System.out.println("Controller: received request to add student");
        studentService.addStudent(s);
    }

    public void getStudent(int id) {
        Student s = studentService.getStudent(id);
        System.out.println("Found: " + s);
    }

    public void getAllStudents() {
        List<Student> list = studentService.getAllStudents();
        list.forEach(System.out::println);
    }
}
```

