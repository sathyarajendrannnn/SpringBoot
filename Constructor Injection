### 📌 Handling Ambiguity in constructor-arg

When Spring can't figure out which arg is which, use `index`, `name`, or `type`:

```xml
<!-- By index (0-based) -->
<bean id="student" class="com.example.Student">
    <constructor-arg index="0" value="Nivas"/>
    <constructor-arg index="1" value="21"/>
    <constructor-arg index="2" ref="address"/>
</bean>

<!-- By name -->
<bean id="student" class="com.example.Student">
    <constructor-arg name="name"    value="Nivas"/>
    <constructor-arg name="age"     value="21"/>
    <constructor-arg name="address" ref="address"/>
</bean>

<!-- By type -->
<bean id="student" class="com.example.Student">
    <constructor-arg type="java.lang.String" value="Nivas"/>
    <constructor-arg type="int"              value="21"/>
    <constructor-arg type="com.example.Address" ref="address"/>
</bean>
```

